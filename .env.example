# ==============================
# Wildberries API
# ==============================
WB_API_TOKEN=your_wb_api_token_here

# ==============================
# PostgreSQL
# ==============================
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=postgres

# ==============================
# Google Sheets
# ==============================
# Через запятую ID таблиц, в которые будут выгружаться тарифы
GOOGLE_SHEET_IDS=your_google_sheet_id_1,your_google_sheet_id_2
# Имя листа в Google-таблице
GOOGLE_SHEET_NAME=stocks_coefs

# ==============================
# Расписание (cron expressions)
# ==============================
# Получение тарифов WB (по умолчанию — каждый час)
FETCH_CRON=0 * * * *
# Синхронизация с Google Sheets (по умолчанию — каждые 5 минут)
SHEETS_SYNC_CRON=*/5 * * * *
