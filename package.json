{
  "name": "wb-tariffs-service",
  "version": "1.0.0",
  "description": "Сервис для получения тарифов WB (коробы), сохранения в PostgreSQL и экспорта в Google Sheets",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "seed": "knex seed:run"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "google-spreadsheet": "^4.1.4",
    "google-auth-library": "^9.14.2",
    "knex": "^3.1.0",
    "node-cron": "^3.0.3",
    "pg": "^8.13.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
